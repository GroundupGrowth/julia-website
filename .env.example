# Neon Postgres connection string. Get from Neon dashboard → your project → Connection details.
# Use the pooled URL for the serverless driver.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Admin CMS (Phase 1) ---
# Auth is provided by Neon Auth (Stack). When you enable the Neon Auth
# integration on Vercel, these three are auto-injected — you don't need to
# copy them locally unless you're running `next dev` against the same
# Neon project.
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# Optional comma-separated allowlist of email addresses that may sign into
# /admin. Leave unset to allow any signed-in Neon Auth user (safe when
# Stack's public sign-up is disabled in the Stack dashboard).
ADMIN_EMAILS=
