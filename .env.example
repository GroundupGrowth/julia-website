# Neon Postgres connection string. Get from Neon dashboard → your project → Connection details.
# Use the pooled URL for the serverless driver.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Admin CMS (Phase 1) ---
# Single-tenant admin user. Login is gated by these two values.
ADMIN_EMAIL=admin@example.com
# bcrypt hash of the admin password. Generate with:
#   node -e "require('bcryptjs').hash(process.argv[1],10).then(h=>console.log(h))" 'your-password'
ADMIN_PASSWORD_HASH=

# 32+ character random string used to seal the iron-session cookie.
# Generate with: openssl rand -base64 48
SESSION_PASSWORD=
